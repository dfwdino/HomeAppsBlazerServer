@page "/ShoppingList"


@using HomeAppsBlazerServer.Components.Pages.Shopping.PriceHistory
@using HomeAppsBlazerServer.Models
@using HomeAppsBlazerServer.Models.Shopping
@using HomeAppsBlazerServer.Servcies
@using HomeAppsBlazerServer.Servcies.Shopping

@*Endalbes it*@
@* @rendermode InteractiveServer *@

@* jackes up the view of the table *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))


@* Loads as it as it download it. *@
@attribute [StreamRendering]

@inject IShoppingServices ShoppingServices

@inject NavigationManager NavigationManger
@inject IJSRuntime JsRuntime

@layout HomeAppsBlazerServer.Components.Layout.Shopping.ShoppingLayout

<PageTitle>Shopping List</PageTitle>
<h3>Shopping Items</h3>  
<br />
<span onclick="@OnHideShowMenu">@HideMenuText</span>


<!-- Main Navigation -->
<div class="shopping-nav card mb-4" >
    <div class="card-body p-3" style="display: @(isNavVisible ? "block" : "none")">
        <nav class="nav nav-pills">
            <NavLink class="nav-link" href="ShoppingItems" Match="NavLinkMatch.All">
                All Items
            </NavLink>
            <NavLink class="nav-link" href="CreateEditListItem">
                Add to List
            </NavLink>
            <NavLink class="nav-link" href="edit-item">
                Add New
            </NavLink>
        </nav>
    </div>
</div>

<!-- Shopping List Content -->

<div class="shopping-list-container" id="shopping-list-container">
    @if (CurrentShoppingList is null)
    {
        <div class="alert alert-info">
            <div class="d-flex align-items-center">
                <div class="spinner-border spinner-border-sm me-2" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <span>Loading list items...</span>
            </div>
        </div>
    }
    else if (CurrentShoppingList.Count.Equals(0))
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            No items found in the list.
        </div>
    }
    else
    {
        <ShoppingListNeedDate Items="@ItemsNeededNow.ToList()"
                              FilterDate="@DateTime.Now.AddDays(-daysAhead)"
                OnItemClick="@GotItem"
                OnShowHistory="@ShowHistory"
                ItemOut = "@ItemOut"
                OnEditItem="@EditItem" />

                <br />
                <hr >
                <br />

        <ShoppingListNeedDate Items="@ItemsNeededFuture.ToList()"
                              FilterDate="@DateTime.Now.AddDays(daysAhead)"
                OnItemClick="@GotItem"
                OnShowHistory="@ShowHistory"
                ItemOut="@ItemOut"
                OnEditItem="@EditItem" />

    }
</div>

<PriceHistoryOverview @ref="popupRef" />

<!-- Add these styles to your component or stylesheet -->
<style>



    .shopping-nav .nav-link {
        color: #4a5568;
        border-radius: 0.375rem;
        transition: all 0.2s ease;
    }

        .shopping-nav .nav-link:hover {
            background-color: #e2e8f0;
        }

        .shopping-nav .nav-link.active {
            background-color: #3182ce;
            color: white;
        }

    .shopping-list-container {
        max-width: 1100px;
        margin: 0 auto;
    }

    .item-details {
        font-size: 0.9rem;
    }

    @@media (max-width: 768px) {
        .item-details {
            margin-top: 0.25rem;
        }
    }
</style>

<!-- Add Bootstrap Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">


@implements IAsyncDisposable

@code {
    List<ShoppingItemResult> CurrentShoppingList;
    private bool isNavVisible = false;
    private string HideMenuText = "Show Menu";

    private PriceHistoryOverview popupRef;
    private string ItemName = string.Empty;

    private int daysAhead = 2;

    IEnumerable<ShoppingItemResult> ItemsNeededNow;
    IEnumerable<ShoppingItemResult> ItemsNeededFuture;

    private DotNetObjectReference<ShoppingListOverview> _dotNetRef;


    private void OnHideShowMenu()
    {
        isNavVisible = !isNavVisible;
        HideMenuText = isNavVisible ? "Hide Menu" : "Show Menu";
    }
    private void ShowHistory(int id)
    {

        List<PriceHistory> ItemPriceHistory =  ShoppingServices.GetPriceHisotry(id).Result;

        ItemName = CurrentShoppingList.FirstOrDefault(mm => mm.ItemID == id)?.ItemName;

        popupRef.Show(ItemPriceHistory, ItemName);
    }


    protected override async Task OnInitializedAsync()
    {
        CurrentShoppingList = await GetShoppingItems();

        ItemsNeededFuture = CurrentShoppingList.Where(mm => mm.NeedDate >= DateTime.Now.AddDays(daysAhead));

        ItemsNeededNow = CurrentShoppingList.Where(mm => mm.NeedDate <= DateTime.Now.AddDays(daysAhead)  || mm.NeedDate is null).OrderBy(mm => mm.ItemName);

    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JsRuntime.InvokeVoidAsync("requestWakeLock");
            await JsRuntime.InvokeVoidAsync("registerSwipeGestures", "shopping-list-container", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task HandleSwipeGot(int shoppingItemListId)
    {
        var item = CurrentShoppingList.FirstOrDefault(i => i.ShoppingItemListID == shoppingItemListId);
        if (item is not null)
        {
            await GotItem(item);
            await InvokeAsync(StateHasChanged); // JS callbacks don't auto-trigger a re-render
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JsRuntime.InvokeVoidAsync("releaseWakeLock");
        }
        catch (JSDisconnectedException)
        {
            // Circuit already gone on page refresh — safe to ignore
        }
        _dotNetRef?.Dispose();
    }

    async Task<List<ShoppingItemResult>> GetShoppingItems()
    {
        //TODO: should be cached
        return await ShoppingServices.GetAllNeedItemsAsync();
    }

    void EditItem(int id)
    {
        NavigationManger.NavigateTo($"CreateEditListItem/{id}");
    }

    async Task ItemOut(ShoppingItemResult itemgot)
    {
        itemgot.NeedDate = DateTime.Now.AddDays(7);
        await ShoppingServices.UpdateNeedList(itemgot);
    }

    async Task GotItem(ShoppingItemResult itemgot)
    {
        bool success = await ShoppingServices.GotItem(itemgot.ShoppingItemListID);

        if (success)
            CurrentShoppingList.Remove(itemgot);
        
            //await JsRuntime.InvokeVoidAsync("alert", "Item Added");

    }


}
