@page "/Add-Car"
@page "/Add-Car/{CarId:int}"
@using System.ComponentModel.DataAnnotations
@using HomeAppsBlazerServer.Models.Auto
@using HomeAppsBlazerServer.Servcies.Auto
@inject NavigationManager Navigation
@inject CarService CarService
@rendermode @(new InteractiveServerRenderMode(false))
@attribute [StreamRendering]

@layout HomeAppsBlazerServer.Components.Layout.Cars.CarLayout

<PageTitle>@(IsEdit ? "Edit Car" : "Add Car")</PageTitle>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="card border-0 shadow-sm" style="border-top: 3px solid #0d6efd !important; border-radius: 12px; overflow: hidden;">

                <div class="card-header bg-white border-bottom d-flex align-items-center gap-2 py-3 px-4">
                    <div class="rounded-2 d-flex align-items-center justify-content-center"
                         style="width:36px; height:36px; background:#e8f0fe;">
                        <i class="bi @(IsEdit ? "bi-pencil" : "bi-plus-lg") text-primary" style="font-size:14px;"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-medium">@(IsEdit ? "Edit car" : "Add car")</h5>
                        <small class="text-muted">@(IsEdit ? "Update the details below" : "Fill in the details below")</small>
                    </div>
                </div>

                <div class="card-body px-4 py-4">
                    <EditForm Model="@Car" OnValidSubmit="@HandleValidSubmit" FormName="carForm">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger small mb-3" />

                        <!-- Make field -->
                        <div class="mb-4">
                            <label class="form-label text-uppercase fw-medium small text-secondary" for="make">
                                Make
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="bi bi-car-front text-secondary" style="font-size:14px;"></i>
                                </span>
                                <InputText @bind-Value="Car.Name"
                                           class="form-control border-start-0"
                                           id="make"
                                           placeholder="e.g. Toyota, Ford, Honda"
                                           maxlength="50" />
                            </div>
                            <ValidationMessage For="@(() => Car.Name)" class="text-danger small mt-1" />
                        </div>

                        <!-- Date added (edit mode only, read-only display) -->
                        @if (IsEdit)
                        {
                            <div class="mb-4">
                                <label class="form-label text-uppercase fw-medium small text-secondary">
                                    Date added
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">
                                        <i class="bi bi-calendar3 text-secondary" style="font-size:14px;"></i>
                                    </span>
                                    <p class="form-control border-start-0 bg-light text-muted mb-0"
                                           style="line-height: 38px;">
                                        @Car.DateAdded.ToShortDateString()
                                    </p>
                                </div>
                                <small class="text-muted mt-1 d-block">This field cannot be modified</small>
                            </div>
                        }

                        <hr class="my-3" />

                        <!-- Actions -->
                        <div class="d-flex justify-content-between align-items-center">
                            <button type="button"
                                    class="btn btn-outline-secondary px-4"
                                    @onclick="Cancel">
                                <i class="bi bi-x me-1"></i> Cancel
                            </button>

                            <button type="submit"
                                    class="btn btn-primary px-4"
                                    disabled="@Processing">
                                @if (Processing)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Processing...</span>
                                }
                                else
                                {
                                    <i class="bi @(IsEdit ? "bi-check-lg" : "bi-plus-lg") me-1"></i>
                                    @(IsEdit ? "Update car" : "Add car")
                                }
                            </button>
                        </div>

                    </EditForm>
                </div>

                <!-- Alerts inside the card -->
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-danger d-flex align-items-start gap-2 mx-4 mb-4 py-2" role="alert">
                        <i class="bi bi-exclamation-circle-fill mt-1" style="font-size:14px;"></i>
                        <span>@ErrorMessage</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(SuccessMessage))
                {
                    <div class="alert alert-success d-flex align-items-start gap-2 mx-4 mb-4 py-2" role="alert">
                        <i class="bi bi-check-circle-fill mt-1" style="font-size:14px;"></i>
                        <span>@SuccessMessage</span>
                    </div>
                }

            </div>

        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? CarId { get; set; }

    [SupplyParameterFromForm]
    public Car Car { get; set; } = new();

    private bool Processing { get; set; }
    private string? ErrorMessage { get; set; }
    private string? SuccessMessage { get; set; }
    private bool IsEdit => CarId.HasValue;

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit)
        {
            await LoadCar();
        }
        else
        {
            // New car, set current date
            Car.DateAdded = DateTime.Now;
        }
    }

    private async Task LoadCar()
    {
        try
        {
            var car = await CarService.GetByIdAsync(CarId!.Value);
            if (car == null)
            {
                ErrorMessage = "Car not found.";
                return;
            }

            Car = new Car
            {
                CarID = car.CarID,
                Name = car.Name,
                DateAdded = car.DateAdded
            };
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error loading car: {ex.Message}";
        }
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            Processing = true;
            ErrorMessage = null;
            SuccessMessage = null;

            if (IsEdit)
            {
                await CarService.UpdateAsync(new Car
                {
                    CarID = Car.CarID,
                    Name = Car.Name,
                    DateAdded = Car.DateAdded
                });
                SuccessMessage = "Car updated successfully!";
            }
            else
            {
                await CarService.CreateAsync(new Car
                {
                        Name = Car.Name,
                    DateAdded = Car.DateAdded
                });
                SuccessMessage = "Car added successfully!";
            }

            // Optional: Navigate back to the list after a delay
            await Task.Delay(1500);
            Navigation.NavigateTo("List-Car");
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error {(IsEdit ? "updating" : "adding")} car: {ex.Message}";
        }
        finally
        {
            Processing = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("List-Car");
    }
}